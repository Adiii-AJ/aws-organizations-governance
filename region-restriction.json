{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "RegionRestriction",
      "Effect": "Deny",
      "NotAction": [
        "iam:*",
        "organizations:*",
        "route53:*",
        "cloudfront:*"
      ],
      "Resource": "*",
      "Condition": {
        "StringNotEquals": {
          "aws:RequestedRegion": [
            "ap-south-1"
          ]
        }
      }
    }
  ]
}
